<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane fx:id="rootPane" styleClass="rootPane" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.AuctionListController">
   <children>
      <VBox prefHeight="600.0" prefWidth="800.0" spacing="15.0" styleClass="content-pane">
          <padding>
              <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
          </padding>
          <children>
              <HBox alignment="CENTER_LEFT" spacing="10.0">
                  <children>
                      <VBox spacing="2.0">
                          <children>
                              <Label styleClass="section-title" text="DANH SÁCH PHIÊN ĐẤU GIÁ" />
                              <Label fx:id="messageLabel" styleClass="status-message-label" text="Đang tải dữ liệu..." />
                          </children>
                      </VBox>
                      <Region HBox.hgrow="ALWAYS" />
                      <HBox spacing="10.0">
                          <children>
                              <Button mnemonicParsing="false" onAction="#handleRefresh" styleClass="btn-secondary" text="Làm mới" />
                              <Button mnemonicParsing="false" onAction="#handleViewDetail" styleClass="btn-primary" text="Xem chi tiết" />
                              <Button mnemonicParsing="false" onAction="#handleBack" styleClass="btn-danger" text="Quay lại" />
                          </children>
                      </HBox>
                  </children>
              </HBox>
      
              <TableView fx:id="auctionTable" prefHeight="200.0" prefWidth="200.0" styleClass="auction-table" VBox.vgrow="ALWAYS">
                  <columns>
                      <TableColumn fx:id="itemNameColumn" minWidth="200.0" prefWidth="-1.0" text="Tên vật phẩm" />
                      <TableColumn fx:id="currentPriceColumn" minWidth="150.0" prefWidth="-1.0" text="Giá hiện tại" />
                      <TableColumn fx:id="statusColumn" minWidth="120.0" prefWidth="-1.0" text="Trạng thái" />
                      <TableColumn fx:id="endTimeColumn" minWidth="180.0" prefWidth="-1.0" text="Thời gian kết thúc" />
                  </columns>
                  <columnResizePolicy>
                      <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                  </columnResizePolicy>
              </TableView>
          </children>
      </VBox>
      <ToggleButton fx:id="btnTheme" mnemonicParsing="false" onAction="#toggleTheme" prefHeight="45.0" prefWidth="45.0" styleClass="button" text="🌙" textAlignment="CENTER" StackPane.alignment="BOTTOM_RIGHT">
         <font>
            <Font size="19.0" />
         </font>
         <StackPane.margin>
            <Insets bottom="25.0" right="25.0" />
         </StackPane.margin>
      </ToggleButton>
   </children>
</StackPane>
