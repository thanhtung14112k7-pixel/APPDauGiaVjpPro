<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.paint.RadialGradient?>
<?import javafx.scene.paint.Stop?>
<?import javafx.scene.text.Font?>

<!--
    register.fxml là giao diện đăng ký tài khoản phía Client.

    Vai trò:
    - Hiển thị form nhập username, email, password, repeat password.
    - Cho người dùng chọn role bằng roleComboBox.
    - Gắn các control với RegisterController thông qua fx:id.
    - Khi bấm Register, JavaFX gọi RegisterController.handleRegister().
    - Khi bấm Login?, JavaFX gọi RegisterController.goToLogin().

    Lưu ý:
    - File FXML chỉ mô tả giao diện.
    - Không xử lý logic đăng ký trong FXML.
    - Logic đăng ký nằm trong RegisterController.
-->

<StackPane fx:id="rootContainer" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" stylesheets="@light.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.RegisterController">

   <children>

      <Pane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="768.0" prefWidth="1024.0" styleClass="main-container">

         <children>

            <VBox alignment="CENTER" layoutX="257.0" layoutY="68.0" prefHeight="630.0" prefWidth="510.0" spacing="15.0" styleClass="login-card">

               <children>

                  <!-- Logo của ứng dụng -->
                  <ImageView fitHeight="105.0" fitWidth="236.0" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../../../../image/LOGO.png" />
                     </image>
                  </ImageView>

                  <!-- Tiêu đề màn hình đăng ký -->
                  <Label alignment="CENTER" minHeight="50.0" prefHeight="60.0" prefWidth="260.0" styleClass="welcome-text" text="Create Account" textAlignment="JUSTIFY">

                     <textFill>
                        <RadialGradient centerX="0.5" centerY="0.5" radius="0.5">
                           <stops>
                              <Stop>
                                 <color>
                                    <Color />
                                 </color>
                              </Stop>
                              <Stop offset="1.0">
                                 <color>
                                    <Color red="1.0" green="1.0" blue="1.0" />
                                 </color>
                              </Stop>
                           </stops>
                        </RadialGradient>
                     </textFill>

                     <VBox.margin>
                        <Insets bottom="10.0" />
                     </VBox.margin>
                  </Label>

                  <!--
                      usernameField khớp với biến:
                      @FXML private TextField usernameField;
                      trong RegisterController.
                  -->
                  <TextField fx:id="usernameField" prefHeight="47.0" prefWidth="313.0" promptText="Username" styleClass="text-input" />

                  <!--
                      emailField khớp với biến:
                      @FXML private TextField emailField;
                      trong RegisterController.
                  -->
                  <TextField fx:id="emailField" prefHeight="47.0" prefWidth="313.0" promptText="Email" styleClass="text-input" />

                  <!--
                      passwordField là mật khẩu chính.
                      Dùng PasswordField để không hiện ký tự thật khi nhập.
                  -->
                  <PasswordField fx:id="passwordField" prefHeight="47.0" prefWidth="313.0" promptText="Password" styleClass="text-input" />

                  <!--
                      confirmPasswordField là ô nhập lại mật khẩu.
                      RegisterController sẽ kiểm tra có trùng passwordField không.
                  -->
                  <PasswordField fx:id="confirmPasswordField" prefHeight="47.0" prefWidth="313.0" promptText="Repeat password" styleClass="text-input" />

                  <!--
                      roleComboBox cho người dùng chọn vai trò tài khoản.
                      Danh sách BIDDER/SELLER được thêm trong RegisterController.initialize().
                  -->
                  <ComboBox fx:id="roleComboBox" prefHeight="47.0" prefWidth="313.0" promptText="Role" styleClass="combo-custom" />

                  <!--
                      errorLabel dùng để hiển thị lỗi hoặc thông báo thành công.
                      Ban đầu ẩn, khi có lỗi RegisterController sẽ setVisible(true).
                  -->
                  <Label fx:id="errorLabel" maxHeight="40.0" minHeight="40.0" prefHeight="40.0" text="" visible="false" wrapText="true" />
                  <Hyperlink alignment="CENTER" contentDisplay="CENTER" onAction="#goToLogin" prefHeight="24.0" prefWidth="267.0" styleClass="second_label" text="Already have an account?" textAlignment="JUSTIFY" />

                  <!--
                      Khi bấm Login?, JavaFX gọi RegisterController.goToLogin().
                  -->
                  <Hyperlink alignment="CENTER" contentDisplay="CENTER" onAction="#goToLogin" prefHeight="24.0" prefWidth="267.0" styleClass="second_label" text="Login?" textAlignment="JUSTIFY" />

                  <!--
                      Khi bấm Register, JavaFX gọi RegisterController.handleRegister().
                  -->
                  <Button alignment="CENTER" mnemonicParsing="false" onAction="#handleRegister" prefHeight="31.0" prefWidth="211.0" text="Register" textAlignment="JUSTIFY" />

               </children>

               <padding>
                  <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
               </padding>

            </VBox>

         </children>
      </Pane>

      <!--
          Nút đổi theme sáng/tối.
          Khi bấm, JavaFX gọi RegisterController.toggleTheme().
      -->
      <ToggleButton fx:id="btnTheme" mnemonicParsing="false" onAction="#toggleTheme" prefHeight="45.0" prefWidth="45.0" styleClass="button" text="🌙" textAlignment="CENTER" StackPane.alignment="BOTTOM_RIGHT">

         <font>
            <Font size="19.0" />
         </font>

         <StackPane.margin>
            <Insets bottom="25.0" right="25.0" />
         </StackPane.margin>

      </ToggleButton>

   </children>
</StackPane>
